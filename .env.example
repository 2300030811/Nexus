# Nexus Platform Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_password

# Database connection settings (used by application services)
PG_HOST=postgres
PG_PORT=5432
PG_DB=nexus
PG_USER=nexus
PG_PASSWORD=nexus_password

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC=order_events

# Event generation rate (events per second)
EVENTS_PER_SECOND=2.0

# =============================================================================
# Ollama / LLM Configuration
# =============================================================================
OLLAMA_HOST=ollama:11434
OLLAMA_MODEL=llama3

# =============================================================================
# Service Intervals (in seconds)
# =============================================================================
# Anomaly detection scan interval
SCAN_INTERVAL=60

# AI Copilot investigation interval
COPILOT_INTERVAL=90

# =============================================================================
# Spark Configuration
# =============================================================================
CHECKPOINT_DIR=/opt/spark-checkpoints

# =============================================================================
# Dashboard Configuration
# =============================================================================
# WARNING: Change this password before deploying to production
DASHBOARD_PASSWORD=nexus_secure_pass_123

# =============================================================================
# Notes
# =============================================================================
# - Database credentials should be strong passwords in production
# - All services use these environment variables via docker-compose
# - Service-to-service communication uses Docker internal networking
# - Only ports 8501 (dashboard), 9092 (Kafka), 5432 (PostgreSQL), and 11434 (Ollama) 
#   are exposed to the host by default
