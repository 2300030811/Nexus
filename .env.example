# Nexus Platform Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Database connection settings (used by application services)
PG_HOST=postgres
PG_PORT=5432
PG_DB=nexus
PG_USER=nexus
PG_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC=order_events

# Event generation rate (events per second)
EVENTS_PER_SECOND=2.0

# =============================================================================
# Ollama / LLM Configuration
# =============================================================================
OLLAMA_HOST=ollama:11434
OLLAMA_MODEL=llama3

# =============================================================================
# Service Intervals (in seconds)
# =============================================================================
# Anomaly detection scan interval
SCAN_INTERVAL=60

# AI Copilot investigation interval
COPILOT_INTERVAL=90

# =============================================================================
# Spark Configuration
# =============================================================================
CHECKPOINT_DIR=/opt/spark-checkpoints
KAFKA_STARTING_OFFSETS=latest
KAFKA_FAIL_ON_DATA_LOSS=true
KAFKA_MAX_OFFSETS_PER_TRIGGER=10000

# =============================================================================
# Dashboard Configuration
# =============================================================================
# Required outside local development
DASHBOARD_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD

# =============================================================================
# Security
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8501

# API auth key (required when ENV is not development/local/test)
API_KEY=CHANGE_ME_API_KEY

# Grafana admin password
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Environment mode: 'development' skips secrets validation, 'production' enforces it
ENV=development

# =============================================================================
# Observability
# =============================================================================
# Prometheus metrics ports (internal only — not exposed to host)
PRODUCER_METRICS_PORT=9090
ANOMALY_METRICS_PORT=9091
COPILOT_METRICS_PORT=9093

# Webhook URL for critical anomaly alerts (optional — leave empty to disable)
ALERT_WEBHOOK_URL=

# =============================================================================
# ML Configuration
# =============================================================================
# Minimum samples required before retraining (prevents retraining on sparse data)
MIN_RETRAIN_SAMPLES=1000

# Model path override (useful for testing a candidate model before promoting it)
MODEL_PATH=/app/model/model.json

# =============================================================================
# Notes
# =============================================================================
# - Database credentials should be strong passwords in production
# - All services use these environment variables via docker-compose
# - Service-to-service communication uses Docker internal networking
# - Only ports 8501 (dashboard), 9092 (Kafka), 5432 (PostgreSQL), and 11434 (Ollama) 
#   are exposed to the host by default
